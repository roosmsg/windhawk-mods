ClickAction ReadActionSetting(PCWSTR settingName,
                              ClickAction defaultAction) {
    PCWSTR value = Wh_GetStringSetting(settingName);

    ClickAction result = defaultAction;
    if (wcscmp(value, L"openQuickSettings") == 0) {
        result = ClickAction::OpenQuickSettings;
    } else if (wcscmp(value, L"openNotifications") == 0) {
        result = ClickAction::OpenNotifications;
    } else if (wcscmp(value, L"openTarget") == 0) {
        result = ClickAction::OpenTarget;
    } else if (wcscmp(value, L"doNothing") == 0) {
        result = ClickAction::DoNothing;
    }

    Wh_FreeStringSetting(value);
    return result;
}

std::wstring ReadStringSetting(PCWSTR settingName) {
    PCWSTR value = Wh_GetStringSetting(settingName);
    std::wstring result = value;
    Wh_FreeStringSetting(value);
    return result;
}

void LoadSettings() {
    Settings settings;
    settings.leftClickAction =
        ReadActionSetting(L"leftClickAction", ClickAction::OpenNotifications);
    settings.leftClickTarget = ReadStringSetting(L"leftClickTarget");
    settings.middleClickAction =
        ReadActionSetting(L"middleClickAction", ClickAction::DoNothing);
    settings.middleClickTarget = ReadStringSetting(L"middleClickTarget");
    settings.rightClickAction =
        ReadActionSetting(L"rightClickAction", ClickAction::OpenQuickSettings);
    settings.rightClickTarget = ReadStringSetting(L"rightClickTarget");
    settings.enableTrayTextColor = Wh_GetIntSetting(L"enableTrayTextColor");
    settings.trayTextColor = ReadStringSetting(L"trayTextColor");

    std::lock_guard<std::mutex> guard(g_settingsMutex);
    g_settings = std::move(settings);
}

struct ClickActionSnapshot {
    ClickAction action;
    std::wstring target;
};

ClickActionSnapshot GetActionSnapshot(MouseButton button) {
    std::lock_guard<std::mutex> guard(g_settingsMutex);

    if (button == MouseButton::Right) {
        return {g_settings.rightClickAction, g_settings.rightClickTarget};
    }

    if (button == MouseButton::Middle) {
        return {g_settings.middleClickAction, g_settings.middleClickTarget};
    }

    return {g_settings.leftClickAction, g_settings.leftClickTarget};
}

struct TrayTextColorSnapshot {
    bool enabled;
    std::wstring color;
};

TrayTextColorSnapshot GetTrayTextColorSnapshot() {
    std::lock_guard<std::mutex> guard(g_settingsMutex);
    return {g_settings.enableTrayTextColor, g_settings.trayTextColor};
}

PCWSTR MouseButtonName(MouseButton button) {
    switch (button) {
        case MouseButton::Left:
            return L"Left";

        case MouseButton::Middle:
            return L"Middle";

        case MouseButton::Right:
            return L"Right";

        default:
            return L"Unknown";
    }
}

void SendWindowsShortcut(WORD virtualKey) {
    INPUT inputs[4]{};

    inputs[0].type = INPUT_KEYBOARD;
    inputs[0].ki.wVk = VK_LWIN;

    inputs[1].type = INPUT_KEYBOARD;
    inputs[1].ki.wVk = virtualKey;

    inputs[2].type = INPUT_KEYBOARD;
    inputs[2].ki.wVk = virtualKey;
    inputs[2].ki.dwFlags = KEYEVENTF_KEYUP;

    inputs[3].type = INPUT_KEYBOARD;
    inputs[3].ki.wVk = VK_LWIN;
    inputs[3].ki.dwFlags = KEYEVENTF_KEYUP;

    if (SendInput(ARRAYSIZE(inputs), inputs, sizeof(INPUT)) !=
        ARRAYSIZE(inputs)) {
        Wh_Log(L"SendInput failed: %u", GetLastError());
    }
}

std::wstring ExpandTarget(std::wstring_view target) {
    if (target.empty()) {
        return {};
    }

    std::wstring source(target);
    DWORD required = ExpandEnvironmentStringsW(source.c_str(), nullptr, 0);
    if (required == 0) {
        return source;
    }

    std::wstring expanded(required, L'\0');
    DWORD copied = ExpandEnvironmentStringsW(source.c_str(), expanded.data(),
                                             required);
    if (copied == 0 || copied > required) {
        return source;
    }

    if (!expanded.empty() && expanded.back() == L'\0') {
        expanded.pop_back();
    }

    return expanded;
}

void OpenTarget(std::wstring_view target) {
    std::wstring expandedTarget = ExpandTarget(target);
    if (expandedTarget.empty()) {
        Wh_Log(L"Custom target is empty");
        return;
    }

    HINSTANCE result = ShellExecuteW(nullptr, L"open", expandedTarget.c_str(),
                                     nullptr, nullptr, SW_SHOWNORMAL);
    if ((INT_PTR)result <= 32) {
        Wh_Log(L"ShellExecute failed for \"%s\": %d", expandedTarget.c_str(),
               (int)(INT_PTR)result);
    }
}

void ExecuteAction(MouseButton button) {
    ClickActionSnapshot snapshot = GetActionSnapshot(button);

    switch (snapshot.action) {
        case ClickAction::OpenQuickSettings:
            SendWindowsShortcut(L'A');
            break;

        case ClickAction::OpenNotifications:
            SendWindowsShortcut(L'N');
            break;

        case ClickAction::OpenTarget:
            OpenTarget(snapshot.target);
            break;

        case ClickAction::DoNothing:
            break;
    }
}

bool IsTaskbarWindow(HWND hWnd) {
    WCHAR className[64];
    if (!GetClassName(hWnd, className, ARRAYSIZE(className))) {
        return false;
    }

    return _wcsicmp(className, L"Shell_TrayWnd") == 0 ||
           _wcsicmp(className, L"Shell_SecondaryTrayWnd") == 0;
}

HWND FindCurrentProcessTaskbarWnd() {
    HWND taskbarWnd = nullptr;

    EnumWindows(
        [](HWND hWnd, LPARAM lParam) -> BOOL {
            DWORD processId = 0;
            WCHAR className[64];
            if (GetWindowThreadProcessId(hWnd, &processId) &&
                processId == GetCurrentProcessId() &&
                GetClassName(hWnd, className, ARRAYSIZE(className)) &&
                _wcsicmp(className, L"Shell_TrayWnd") == 0) {
                *reinterpret_cast<HWND*>(lParam) = hWnd;
                return FALSE;
            }

            return TRUE;
        },
        reinterpret_cast<LPARAM>(&taskbarWnd));

    return taskbarWnd;
}

std::vector<HWND> FindCurrentProcessTaskbarWindows() {
    std::vector<HWND> result;

    HWND primaryTaskbar = FindCurrentProcessTaskbarWnd();
    if (!primaryTaskbar) {
        return result;
    }

    result.push_back(primaryTaskbar);

    DWORD taskbarThreadId = GetWindowThreadProcessId(primaryTaskbar, nullptr);
    if (!taskbarThreadId) {
        return result;
    }

    EnumThreadWindows(
        taskbarThreadId,
        [](HWND hWnd, LPARAM lParam) -> BOOL {
            WCHAR className[64];
            if (GetClassName(hWnd, className, ARRAYSIZE(className)) &&
                _wcsicmp(className, L"Shell_SecondaryTrayWnd") == 0) {
                auto taskbars = reinterpret_cast<std::vector<HWND>*>(lParam);
                taskbars->push_back(hWnd);
            }

            return TRUE;
        },
        reinterpret_cast<LPARAM>(&result));

    return result;
}

wux::FrameworkElement FindDescendantByName(wux::FrameworkElement element,
                                           PCWSTR name) {
    if (!element) {
        return nullptr;
    }

    if (element.Name() == name) {
        return element;
    }

    int childrenCount = wuxm::VisualTreeHelper::GetChildrenCount(element);
    for (int i = 0; i < childrenCount; i++) {
        auto child = wuxm::VisualTreeHelper::GetChild(element, i)
                         .try_as<wux::FrameworkElement>();
        if (!child) {
            continue;
        }

        if (auto result = FindDescendantByName(child, name)) {
            return result;
        }
    }

    return nullptr;
}

wux::FrameworkElement FindDescendantByClassName(
    wux::FrameworkElement element,
    PCWSTR className) {
    if (!element) {
        return nullptr;
    }

    if (winrt::get_class_name(element) == className) {
        return element;
    }

    int childrenCount = wuxm::VisualTreeHelper::GetChildrenCount(element);
    for (int i = 0; i < childrenCount; i++) {
        auto child = wuxm::VisualTreeHelper::GetChild(element, i)
                         .try_as<wux::FrameworkElement>();
        if (!child) {
            continue;
        }

        if (auto result = FindDescendantByClassName(child, className)) {
            return result;
        }
    }

    return nullptr;
}

struct TrayTextBlockState {
    winrt::weak_ref<wuxc::TextBlock> textBlock;
    wf::IInspectable originalForeground;
};

std::vector<TrayTextBlockState> g_trayTextBlockStates;

void RestoreTrayTextBlockForeground(wuxc::TextBlock textBlock,
                                    wf::IInspectable originalForeground) {
    auto dependencyObject = textBlock.as<wux::DependencyObject>();
    if (!originalForeground ||
        originalForeground == wux::DependencyProperty::UnsetValue()) {
        dependencyObject.ClearValue(wuxc::TextBlock::ForegroundProperty());
    } else {
        dependencyObject.SetValue(wuxc::TextBlock::ForegroundProperty(),
                                  originalForeground);
    }
}

void RestoreTrayTextColors() {
    for (auto& state : g_trayTextBlockStates) {
        auto textBlock = state.textBlock.get();
        if (!textBlock) {
            continue;
        }

        try {
            RestoreTrayTextBlockForeground(textBlock,
                                           state.originalForeground);
        } catch (...) {
            Wh_Log(L"Failed to restore tray text color: %08X",
                   winrt::to_hresult());
        }
    }

    g_trayTextBlockStates.clear();
}

void ApplyTrayTextColorToTextBlock(wuxc::TextBlock textBlock,
                                   wui::Color color) {
    for (auto it = g_trayTextBlockStates.begin();
         it != g_trayTextBlockStates.end();) {
        auto trackedTextBlock = it->textBlock.get();
        if (!trackedTextBlock) {
            it = g_trayTextBlockStates.erase(it);
            continue;
        }

        if (trackedTextBlock == textBlock) {
            textBlock.Foreground(wuxm::SolidColorBrush{color});
            return;
        }

        ++it;
    }

    auto dependencyObject = textBlock.as<wux::DependencyObject>();
    g_trayTextBlockStates.push_back({
        .textBlock = winrt::make_weak(textBlock),
        .originalForeground = dependencyObject.ReadLocalValue(
            wuxc::TextBlock::ForegroundProperty()),
    });

    textBlock.Foreground(wuxm::SolidColorBrush{color});
}

void ApplyTrayTextColorInSubtree(wux::FrameworkElement element,
                                 wui::Color color) {
    if (!element) {
        return;
    }

    if (winrt::get_class_name(element) == L"SystemTray.ChevronIconView") {
        return;
    }

    if (auto textBlock = element.try_as<wuxc::TextBlock>()) {
        ApplyTrayTextColorToTextBlock(textBlock, color);
    }

    int childrenCount = wuxm::VisualTreeHelper::GetChildrenCount(element);
    for (int i = 0; i < childrenCount; i++) {
        auto child = wuxm::VisualTreeHelper::GetChild(element, i)
                         .try_as<wux::FrameworkElement>();
        if (child) {
            ApplyTrayTextColorInSubtree(child, color);
        }
    }
}

void ApplySystemTrayTextColor(wux::FrameworkElement taskbarRoot) {
    TrayTextColorSnapshot settings = GetTrayTextColorSnapshot();
    if (g_unloading || !settings.enabled) {
        RestoreTrayTextColors();
        return;
    }

    wui::Color color;
    try {
        color = wuxmk::XamlBindingHelper::ConvertValue(
                    winrt::xaml_typename<wui::Color>(),
                    winrt::box_value(settings.color))
                    .as<wui::Color>();
    } catch (...) {
        Wh_Log(L"Invalid system tray text color \"%s\": %08X",
               settings.color.c_str(), winrt::to_hresult());
        RestoreTrayTextColors();
        return;
    }

    auto systemTrayFrame = FindDescendantByClassName(
        taskbarRoot, L"SystemTray.SystemTrayFrame");
    if (!systemTrayFrame) {
        Wh_Log(L"SystemTrayFrame wasn't found");
        return;
    }

    ApplyTrayTextColorInSubtree(systemTrayFrame, color);
}

void ClearTooltipsInSubtree(wux::FrameworkElement element) {
    if (!element) {
        return;
    }

    wuxc::ToolTipService::SetToolTip(
        element, winrt::Windows::Foundation::IInspectable{nullptr});

    int childrenCount = wuxm::VisualTreeHelper::GetChildrenCount(element);
    for (int i = 0; i < childrenCount; i++) {
        auto child = wuxm::VisualTreeHelper::GetChild(element, i)
                         .try_as<wux::FrameworkElement>();
        if (child) {
            ClearTooltipsInSubtree(child);
        }
    }
}

wux::XamlRoot GetTaskbarXamlRoot(HWND taskbarWnd) {
    HWND taskSwWnd = (HWND)GetProp(taskbarWnd, L"TaskbandHWND");
    if (!taskSwWnd) {
        return nullptr;
    }

    void* taskBand = (void*)GetWindowLongPtr(taskSwWnd, 0);
    if (!taskBand) {
        return nullptr;
    }

    void* taskBandForTaskListWndSite = taskBand;
    for (int i = 0; *(void**)taskBandForTaskListWndSite !=
                    CTaskBand_ITaskListWndSite_vftable;
         i++) {
        if (i == 20) {
            return nullptr;
        }

        taskBandForTaskListWndSite = (void**)taskBandForTaskListWndSite + 1;
    }

    void* taskbarHostSharedPtr[2]{};
    CTaskBand_GetTaskbarHost_Original(taskBandForTaskListWndSite,
                                      taskbarHostSharedPtr);
    if (!taskbarHostSharedPtr[0] && !taskbarHostSharedPtr[1]) {
        return nullptr;
    }

    size_t taskbarElementIUnknownOffset = 0x48;

#if defined(_M_X64)
    {
        const BYTE* b = (const BYTE*)TaskbarHost_FrameHeight_Original;
        if (b[0] == 0x48 && b[1] == 0x83 && b[2] == 0xEC && b[4] == 0x48 &&
            b[5] == 0x83 && b[6] == 0xC1 && b[7] <= 0x7F) {
            taskbarElementIUnknownOffset = b[7];
        } else {
            Wh_Log(L"Unsupported TaskbarHost::FrameHeight");
        }
    }
#else
#error "Unsupported architecture"
#endif

    auto* taskbarElementIUnknown =
        *(IUnknown**)((BYTE*)taskbarHostSharedPtr[0] +
                      taskbarElementIUnknownOffset);

    wux::FrameworkElement taskbarElement = nullptr;
    if (taskbarElementIUnknown) {
        taskbarElementIUnknown->QueryInterface(
            winrt::guid_of<wux::FrameworkElement>(),
            winrt::put_abi(taskbarElement));
    }

    wux::XamlRoot result = taskbarElement ? taskbarElement.XamlRoot() : nullptr;

    if (taskbarHostSharedPtr[1]) {
        std__Ref_count_base__Decref_Original(taskbarHostSharedPtr[1]);
    }

    return result;
}

wux::FrameworkElement GetClockButtonElement(HWND taskbarWnd) {
    wux::XamlRoot xamlRoot = GetTaskbarXamlRoot(taskbarWnd);
    if (!xamlRoot) {
        return nullptr;
    }

    auto root = xamlRoot.Content().try_as<wux::FrameworkElement>();
    if (!root) {
        return nullptr;
    }

    ApplySystemTrayTextColor(root);

    auto clockButton = FindDescendantByName(root, L"NotificationCenterButton");
    if (!clockButton ||
        winrt::get_class_name(clockButton) != L"SystemTray.OmniButton") {
        return nullptr;
    }

    ClearTooltipsInSubtree(clockButton);
    return clockButton;
}

bool GetElementScreenRect(wux::FrameworkElement element,
                          HWND hostWnd,
                          RECT* rect) {
    if (!element || !hostWnd) {
        return false;
    }

    double width = element.ActualWidth();
    double height = element.ActualHeight();
    if (width <= 0 || height <= 0) {
        return false;
    }

    auto xamlRoot = element.XamlRoot();
    auto rootElement = xamlRoot.Content().try_as<wux::UIElement>();
    if (!rootElement) {
        return false;
    }

    auto transform = element.TransformToVisual(rootElement);
    wf::Point topLeft = transform.TransformPoint({0, 0});
    wf::Point bottomRight =
        transform.TransformPoint({(float)width, (float)height});

    double scale = xamlRoot.RasterizationScale();
    double left = std::min(topLeft.X, bottomRight.X) * scale;
    double top = std::min(topLeft.Y, bottomRight.Y) * scale;
    double right = std::max(topLeft.X, bottomRight.X) * scale;
    double bottom = std::max(topLeft.Y, bottomRight.Y) * scale;

    RECT hostRect;
    if (!GetWindowRect(hostWnd, &hostRect)) {
        return false;
    }

    rect->left = hostRect.left + (LONG)std::floor(left);
    rect->top = hostRect.top + (LONG)std::floor(top);
    rect->right = hostRect.left + (LONG)std::ceil(right);
    rect->bottom = hostRect.top + (LONG)std::ceil(bottom);
    return rect->right > rect->left && rect->bottom > rect->top;
}

bool IsPointInClockButton(HWND inputSiteWnd, POINT screenPt) {
    HWND bridgeWnd = GetParent(inputSiteWnd);
    HWND taskbarWnd = bridgeWnd ? GetParent(bridgeWnd) : nullptr;
    if (!taskbarWnd || !IsTaskbarWindow(taskbarWnd)) {
        return false;
    }

    wux::FrameworkElement clockButton = GetClockButtonElement(taskbarWnd);
    if (!clockButton) {
        return false;
    }

    RECT clockRect;
    if (!GetElementScreenRect(clockButton, bridgeWnd, &clockRect)) {
        return false;
    }

    return PtInRect(&clockRect, screenPt);
}

bool GetPointerScreenPoint(WPARAM wParam, LPARAM lParam, HWND hWnd, POINT* pt) {
    UINT32 pointerId = GET_POINTERID_WPARAM(wParam);

    POINTER_INFO pointerInfo;
    if (GetPointerInfo(pointerId, &pointerInfo)) {
        *pt = pointerInfo.ptPixelLocation;
        return true;
    }

    pt->x = GET_X_LPARAM(lParam);
    pt->y = GET_Y_LPARAM(lParam);
    return ClientToScreen(hWnd, pt);
}

MouseButton GetPointerButton(WPARAM wParam) {
    if (IS_POINTER_FIRSTBUTTON_WPARAM(wParam)) {
        return MouseButton::Left;
    }

    if (IS_POINTER_SECONDBUTTON_WPARAM(wParam)) {
        return MouseButton::Right;
    }

    if (IS_POINTER_THIRDBUTTON_WPARAM(wParam)) {
        return MouseButton::Middle;
    }

    return MouseButton::None;
}

bool HandlePointerDown(HWND hWnd, WPARAM wParam, LPARAM lParam) {
    MouseButton button = GetPointerButton(wParam);
    if (button == MouseButton::None) {
        return false;
    }

    POINT screenPt;
    if (!GetPointerScreenPoint(wParam, lParam, hWnd, &screenPt)) {
        return false;
    }

    if (!IsPointInClockButton(hWnd, screenPt)) {
        return false;
    }

    UINT32 pointerId = GET_POINTERID_WPARAM(wParam);
    g_suppressedPointerId.store(pointerId, std::memory_order_relaxed);
    g_suppressedMouseButton.store(button, std::memory_order_relaxed);
    g_blockMouseDownUntil.store(GetTickCount() + 200,
                                std::memory_order_relaxed);
    if (button == MouseButton::Right) {
        g_blockContextMenuUntil.store(GetTickCount() + 1000,
                                      std::memory_order_relaxed);
    }

    Wh_Log(L"%s click", MouseButtonName(button));
    ExecuteAction(button);
    return true;
}

bool HandlePointerUp(WPARAM wParam) {
    UINT32 pointerId = GET_POINTERID_WPARAM(wParam);
    return pointerId != 0 &&
           pointerId == g_suppressedPointerId.exchange(
                            0, std::memory_order_relaxed);
}

bool HandleMouseDown(HWND hWnd,
                     MouseButton button,
                     LPARAM lParam) {
    POINT screenPt{GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam)};
    if (!ClientToScreen(hWnd, &screenPt)) {
        return false;
    }

    if (!IsPointInClockButton(hWnd, screenPt)) {
        return false;
    }

    g_suppressedMouseButton.store(button, std::memory_order_relaxed);
    if (button == MouseButton::Right) {
        g_blockContextMenuUntil.store(GetTickCount() + 1000,
                                      std::memory_order_relaxed);
    }

    Wh_Log(L"%s mouse click", MouseButtonName(button));
    ExecuteAction(button);
    return true;
}

bool HandleMouseUp(MouseButton button) {
    return button == g_suppressedMouseButton.exchange(
                         MouseButton::None, std::memory_order_relaxed);
}

LRESULT CALLBACK InputSiteWindowProc_Hook(HWND hWnd,
                                          UINT msg,
                                          WPARAM wParam,
                                          LPARAM lParam) {
    switch (msg) {
        case WM_POINTERDOWN:
            if (HandlePointerDown(hWnd, wParam, lParam)) {
                return 0;
            }
            break;

        case WM_POINTERUP:
            if (HandlePointerUp(wParam)) {
                return 0;
            }
            break;

        case WM_LBUTTONDOWN:
            if ((LONG)(g_blockMouseDownUntil.load(std::memory_order_relaxed) -
                       GetTickCount()) > 0) {
                return 0;
            }
            if (HandleMouseDown(hWnd, MouseButton::Left, lParam)) {
                return 0;
            }
            break;

        case WM_RBUTTONDOWN:
            if ((LONG)(g_blockMouseDownUntil.load(std::memory_order_relaxed) -
                       GetTickCount()) > 0) {
                return 0;
            }
            if (HandleMouseDown(hWnd, MouseButton::Right, lParam)) {
                return 0;
            }
            break;

        case WM_MBUTTONDOWN:
            if ((LONG)(g_blockMouseDownUntil.load(std::memory_order_relaxed) -
                       GetTickCount()) > 0) {
                return 0;
            }
            if (HandleMouseDown(hWnd, MouseButton::Middle, lParam)) {
                return 0;
            }
            break;

        case WM_LBUTTONUP:
            if (HandleMouseUp(MouseButton::Left)) {
                return 0;
            }
            break;

        case WM_RBUTTONUP:
            if (HandleMouseUp(MouseButton::Right)) {
                return 0;
            }
            break;

        case WM_MBUTTONUP:
            if (HandleMouseUp(MouseButton::Middle)) {
                return 0;
            }
            break;

        case WM_CONTEXTMENU: {
            DWORD blockUntil =
                g_blockContextMenuUntil.load(std::memory_order_relaxed);
            if (blockUntil && (LONG)(blockUntil - GetTickCount()) > 0) {
                return 0;
            }
            break;
        }
    }

    return InputSiteWindowProc_Original(hWnd, msg, wParam, lParam);
}

void ApplyTaskbarSettingsForTaskbar(HWND taskbarWnd) {
    GetClockButtonElement(taskbarWnd);
}

using RunFromWindowThreadProc_t = void(WINAPI*)(void* parameter);

bool RunFromWindowThread(HWND hWnd,
                         RunFromWindowThreadProc_t proc,
                         void* procParam) {
    static const UINT runFromWindowThreadRegisteredMsg =
        RegisterWindowMessage(L"Windhawk_RunFromWindowThread_" WH_MOD_ID);

    struct RUN_FROM_WINDOW_THREAD_PARAM {
        RunFromWindowThreadProc_t proc;
        void* procParam;
    };

    DWORD threadId = GetWindowThreadProcessId(hWnd, nullptr);
    if (!threadId) {
        return false;
    }

    if (threadId == GetCurrentThreadId()) {
        proc(procParam);
        return true;
    }

    HHOOK hook = SetWindowsHookEx(
        WH_CALLWNDPROC,
        [](int nCode, WPARAM wParam, LPARAM lParam) -> LRESULT {
            if (nCode == HC_ACTION) {
                const CWPSTRUCT* cwp = (const CWPSTRUCT*)lParam;
                if (cwp->message == runFromWindowThreadRegisteredMsg) {
                    auto* param =
                        (RUN_FROM_WINDOW_THREAD_PARAM*)cwp->lParam;
                    param->proc(param->procParam);
                }
            }

            return CallNextHookEx(nullptr, nCode, wParam, lParam);
        },
        nullptr, threadId);
    if (!hook) {
        return false;
    }

    RUN_FROM_WINDOW_THREAD_PARAM param{proc, procParam};
    SendMessage(hWnd, runFromWindowThreadRegisteredMsg, 0, (LPARAM)&param);

    UnhookWindowsHookEx(hook);
    return true;
}

void ApplyTaskbarSettings() {
    for (HWND taskbarWnd : FindCurrentProcessTaskbarWindows()) {
        RunFromWindowThread(
            taskbarWnd,
            [](void* param) {
                ApplyTaskbarSettingsForTaskbar((HWND)param);
            },
            taskbarWnd);
    }
}

void HandleIdentifiedInputSiteWindow(HWND hWnd) {
    HWND bridgeWnd = GetParent(hWnd);
    WCHAR className[64];
    if (!bridgeWnd || !GetClassName(bridgeWnd, className, ARRAYSIZE(className)) ||
        _wcsicmp(className,
                 L"Windows.UI.Composition.DesktopWindowContentBridge") != 0) {
        return;
    }

    HWND taskbarWnd = GetParent(bridgeWnd);
    if (!taskbarWnd || !IsTaskbarWindow(taskbarWnd)) {
        return;
    }

    DWORD threadId = GetWindowThreadProcessId(taskbarWnd, nullptr);
    if (!threadId) {
        return;
    }

    if (g_inputSiteProcHooked) {
        RunFromWindowThread(
            taskbarWnd,
            [](void* param) {
                ApplyTaskbarSettingsForTaskbar((HWND)param);
            },
            taskbarWnd);
        return;
    }

    if (!g_taskbarThreadId) {
        g_taskbarThreadId = threadId;
    } else if (g_taskbarThreadId != threadId) {
        return;
    }

    void* wndProc = (void*)GetWindowLongPtr(hWnd, GWLP_WNDPROC);
    if (!wndProc) {
        return;
    }

    if (!Wh_SetFunctionHook(wndProc, (void*)InputSiteWindowProc_Hook,
                            (void**)&InputSiteWindowProc_Original)) {
        Wh_Log(L"Failed to hook InputSite wndproc");
        return;
    }

    g_inputSiteProcHooked = true;
    Wh_Log(L"Hooked InputSite wndproc");

    if (g_initialized) {
        Wh_ApplyHookOperations();
    }

    RunFromWindowThread(
        taskbarWnd,
        [](void* param) {
            ApplyTaskbarSettingsForTaskbar((HWND)param);
        },
        taskbarWnd);
}

void FindAndHookInputSiteForTaskbar(HWND taskbarWnd) {
    HWND bridgeWnd = FindWindowEx(
        taskbarWnd, nullptr,
        L"Windows.UI.Composition.DesktopWindowContentBridge", nullptr);
    if (!bridgeWnd) {
        return;
    }

    HWND inputSiteWnd = FindWindowEx(
        bridgeWnd, nullptr, L"Windows.UI.Input.InputSite.WindowClass",
        nullptr);
    if (inputSiteWnd) {
        HandleIdentifiedInputSiteWindow(inputSiteWnd);
    }
}

void FindAndHookExistingInputSites() {
    for (HWND taskbarWnd : FindCurrentProcessTaskbarWindows()) {
        FindAndHookInputSiteForTaskbar(taskbarWnd);
    }
}

void ApplyStartupRetryTimer() {
    if (!g_startupRetryTimer) {
        return;
    }

    LONGLONG dueTime100Ns =
        -static_cast<LONGLONG>(kStartupRetryIntervalMs) * 10000;

    ULARGE_INTEGER dueTime;
    dueTime.QuadPart = static_cast<ULONGLONG>(dueTime100Ns);

    FILETIME dueTimeFt;
    dueTimeFt.dwLowDateTime = dueTime.LowPart;
    dueTimeFt.dwHighDateTime = dueTime.HighPart;

    SetThreadpoolTimer(g_startupRetryTimer, &dueTimeFt,
                       kStartupRetryIntervalMs, 0);
}

void StopStartupRetryTimer() {
    if (!g_startupRetryTimer) {
        return;
    }

    SetThreadpoolTimer(g_startupRetryTimer, nullptr, 0, 0);
    WaitForThreadpoolTimerCallbacks(g_startupRetryTimer, TRUE);
    CloseThreadpoolTimer(g_startupRetryTimer);
    g_startupRetryTimer = nullptr;
}

void StartStartupRetryTimer() {
    if (g_inputSiteProcHooked || g_startupRetryTimer) {
        return;
    }

    g_startupRetryAttempts.store(0, std::memory_order_relaxed);
    g_startupRetryTimer = CreateThreadpoolTimer(
        [](PTP_CALLBACK_INSTANCE, void*, PTP_TIMER timer) {
            if (g_inputSiteProcHooked) {
                SetThreadpoolTimer(timer, nullptr, 0, 0);
                return;
            }

            FindAndHookExistingInputSites();
            ApplyTaskbarSettings();

            int attempts = g_startupRetryAttempts.fetch_add(
                               1, std::memory_order_relaxed) +
                           1;
            if (g_inputSiteProcHooked ||
                attempts >= kStartupRetryMaxAttempts) {
                SetThreadpoolTimer(timer, nullptr, 0, 0);
            }
        },
        nullptr, nullptr);
    if (!g_startupRetryTimer) {
        Wh_Log(L"Failed to create startup retry timer");
        return;
    }

    ApplyStartupRetryTimer();
}

void HandleCreatedWindow(HWND hWnd) {
    if (!hWnd) {
        return;
    }

    WCHAR createdClassName[64];
    if (!GetClassName(hWnd, createdClassName, ARRAYSIZE(createdClassName))) {
        return;
    }

    if (_wcsicmp(createdClassName,
                 L"Windows.UI.Input.InputSite.WindowClass") == 0) {
        HandleIdentifiedInputSiteWindow(hWnd);
    } else if (_wcsicmp(createdClassName,
                        L"Windows.UI.Composition.DesktopWindowContentBridge") ==
               0) {
        HWND taskbarWnd = GetParent(hWnd);
        if (taskbarWnd && IsTaskbarWindow(taskbarWnd)) {
            FindAndHookInputSiteForTaskbar(taskbarWnd);
        }
    } else if (_wcsicmp(createdClassName, L"Shell_TrayWnd") == 0 ||
               _wcsicmp(createdClassName, L"Shell_SecondaryTrayWnd") == 0) {
        FindAndHookInputSiteForTaskbar(hWnd);
    }
}

