constexpr int kHiddenNavigationPaneFileListInsetDip = 30;
constexpr wchar_t kFileListInsetProperty[] =
    L"Windhawk.explorer-toggle-details-pane.FileListInset";

enum class NavigationPaneVisibilityHint : WPARAM {
    Query,
    Visible,
    Hidden,
};

enum class TriggerButton {
    None,
    Left,
    Middle,
};

struct {
    TriggerButton detailsPaneButton;
    TriggerButton navigationPaneButton;
} g_settings;

TriggerButton TriggerButtonFromSetting(PCWSTR settingName) {
    PCWSTR value = Wh_GetStringSetting(settingName);

    TriggerButton button = TriggerButton::None;
    if (value && wcscmp(value, L"left") == 0) {
        button = TriggerButton::Left;
    } else if (value && wcscmp(value, L"middle") == 0) {
        button = TriggerButton::Middle;
    }

    Wh_FreeStringSetting(value);
    return button;
}

void LoadSettings() {
    g_settings.detailsPaneButton =
        TriggerButtonFromSetting(L"detailsPaneButton");
    g_settings.navigationPaneButton =
        TriggerButtonFromSetting(L"navigationPaneButton");
}

bool ButtonHasAction(TriggerButton button) {
    return button != TriggerButton::None &&
           (g_settings.detailsPaneButton == button ||
            g_settings.navigationPaneButton == button);
}

// WM_PARENTNOTIFY only reports button-down events, never double-click
// messages, so DirectUI empty-space left double-clicks are detected from two
// consecutive notifications within the system double-click time and rectangle.
struct EmptySpaceClick {
    HWND hWnd = nullptr;
    DWORD time = 0;
    POINT pt = {};
};

EmptySpaceClick g_lastDefViewEmptyClick;

bool IsSecondClickOfDoubleClick(const EmptySpaceClick& lastClick,
                                HWND hWnd,
                                DWORD time,
                                POINT pt) {
    return lastClick.hWnd == hWnd &&
           time - lastClick.time <= GetDoubleClickTime() &&
           abs(pt.x - lastClick.pt.x) <= GetSystemMetrics(SM_CXDOUBLECLK) &&
           abs(pt.y - lastClick.pt.y) <= GetSystemMetrics(SM_CYDOUBLECLK);
}

void RememberSubclassedWindow(std::vector<HWND>& windows, HWND hWnd) {
    if (std::find(windows.begin(), windows.end(), hWnd) == windows.end()) {
        windows.push_back(hWnd);
    }
}

void ForgetSubclassedWindow(std::vector<HWND>& windows, HWND hWnd) {
    windows.erase(std::remove(windows.begin(), windows.end(), hWnd),
                  windows.end());
}

bool IsWindowClass(HWND hWnd, PCWSTR expectedClassName) {
    if (!hWnd) {
        return false;
    }

    wchar_t className[256] = {};
    GetClassNameW(hWnd, className, ARRAYSIZE(className));
    return wcscmp(className, expectedClassName) == 0;
}

HWND FindShellTabWindowFromChild(HWND hWnd) {
    for (HWND parent = hWnd; parent; parent = GetParent(parent)) {
        if (IsWindowClass(parent, L"ShellTabWindowClass")) {
            return parent;
        }
    }

    return nullptr;
}

bool HasShellTabWindowParent(HWND hWnd) {
    return FindShellTabWindowFromChild(hWnd) != nullptr;
}

bool IsDirectUIEmptySpaceClass(PCWSTR className) {
    return wcscmp(className, L"UIGroupItem") == 0 ||
           wcscmp(className, L"UIItemsView") == 0;
}

void CopyClassName(wchar_t (&dest)[256], PCWSTR src) {
    if (!src) {
        dest[0] = L'\0';
        return;
    }

    wcsncpy(dest, src, ARRAYSIZE(dest) - 1);
    dest[ARRAYSIZE(dest) - 1] = L'\0';
}

bool GetShellBrowserFromChildWindow(HWND hWnd,
                                    winrt::com_ptr<IShellBrowser>& shellBrowser) {
    HWND shellTab = FindShellTabWindowFromChild(hWnd);
    if (!shellTab) {
        return false;
    }

    // WM_GETISHELLBROWSER returns the browser without adding a reference,
    // so copy it with an AddRef; taking ownership would over-release it and
    // eventually crash Explorer.
    IShellBrowser* rawShellBrowser = reinterpret_cast<IShellBrowser*>(
        SendMessageW(shellTab, WM_USER + 7, 0, 0));
    if (!rawShellBrowser) {
        Wh_Log(L"Failed to get IShellBrowser for ShellTabWindowClass %p",
               shellTab);
        return false;
    }

    shellBrowser.copy_from(rawShellBrowser);
    return true;
}

bool GetPerBrowserPropertyBag(IShellBrowser* shellBrowser,
                              winrt::com_ptr<IPropertyBag>& propertyBag) {
    if (!shellBrowser) {
        return false;
    }

    winrt::com_ptr<IServiceProvider> browserServiceProvider;
    HRESULT hr = shellBrowser->QueryInterface(
        IID_PPV_ARGS(browserServiceProvider.put()));
    if (FAILED(hr) || !browserServiceProvider) {
        Wh_Log(L"Failed to query browser service provider: 0x%08X", hr);
        return false;
    }

    winrt::com_ptr<IUnknown> frameManager;
    hr = browserServiceProvider->QueryService(
        kSidFrameManager, IID_PPV_ARGS(frameManager.put()));
    if (FAILED(hr) || !frameManager) {
        Wh_Log(L"Failed to query frame manager: 0x%08X", hr);
        return false;
    }

    winrt::com_ptr<IServiceProvider> frameServiceProvider;
    hr = frameManager->QueryInterface(IID_PPV_ARGS(frameServiceProvider.put()));
    if (FAILED(hr) || !frameServiceProvider) {
        Wh_Log(L"Failed to query frame service provider: 0x%08X", hr);
        return false;
    }

    hr = frameServiceProvider->QueryService(
        kSidPerBrowserPropertyBag, IID_PPV_ARGS(propertyBag.put()));
    if (FAILED(hr) || !propertyBag) {
        Wh_Log(L"Failed to query per-browser property bag: 0x%08X", hr);
        return false;
    }

    return true;
}

bool ReadPerBrowserBoolProperty(HWND hWnd, PCWSTR propertyName, bool* valueOut) {
    if (!valueOut) {
        return false;
    }

    *valueOut = false;

    winrt::com_ptr<IShellBrowser> shellBrowser;
    if (!GetShellBrowserFromChildWindow(hWnd, shellBrowser)) {
        return false;
    }

    winrt::com_ptr<IPropertyBag> propertyBag;
    if (!GetPerBrowserPropertyBag(shellBrowser.get(), propertyBag)) {
        return false;
    }

    VARIANT value;
    VariantInit(&value);
    HRESULT hr = propertyBag->Read(propertyName, &value, nullptr);
    if (FAILED(hr)) {
        Wh_Log(L"Failed to read %s: 0x%08X", propertyName, hr);
        return false;
    }

    bool read = true;
    switch (value.vt) {
        case VT_BOOL:
            *valueOut = value.boolVal != VARIANT_FALSE;
            break;

        case VT_I4:
            *valueOut = value.lVal != 0;
            break;

        case VT_UI4:
            *valueOut = value.ulVal != 0;
            break;

        case VT_EMPTY:
        case VT_NULL:
            *valueOut = false;
            break;

        default:
            Wh_Log(L"Unexpected variant type for %s: %u", propertyName,
                   value.vt);
            read = false;
            break;
    }

    VariantClear(&value);
    return read;
}

bool WritePerBrowserBoolProperty(HWND hWnd, PCWSTR propertyName, bool value) {
    winrt::com_ptr<IShellBrowser> shellBrowser;
    if (!GetShellBrowserFromChildWindow(hWnd, shellBrowser)) {
        return false;
    }

    winrt::com_ptr<IPropertyBag> propertyBag;
    if (!GetPerBrowserPropertyBag(shellBrowser.get(), propertyBag)) {
        return false;
    }

    VARIANT variantValue;
    VariantInit(&variantValue);
    variantValue.vt = VT_BOOL;
    variantValue.boolVal = value ? VARIANT_TRUE : VARIANT_FALSE;

    HRESULT hr = propertyBag->Write(propertyName, &variantValue);
    VariantClear(&variantValue);
    if (FAILED(hr)) {
        Wh_Log(L"Failed to write %s: 0x%08X", propertyName, hr);
        return false;
    }

    return true;
}

bool GetNavigationTreeViewFromShellBrowser(IShellBrowser* shellBrowser,
                                           HWND* treeViewOut) {
    if (!treeViewOut) {
        return false;
    }

    *treeViewOut = nullptr;

    if (!shellBrowser) {
        return false;
    }

    winrt::com_ptr<IServiceProvider> serviceProvider;
    HRESULT hr = shellBrowser->QueryInterface(
        IID_PPV_ARGS(serviceProvider.put()));
    if (FAILED(hr) || !serviceProvider) {
        return false;
    }

    winrt::com_ptr<INameSpaceTreeControl> namespaceTree;
    hr = serviceProvider->QueryService(
        IID_INameSpaceTreeControl, IID_PPV_ARGS(namespaceTree.put()));
    if (FAILED(hr) || !namespaceTree) {
        return false;
    }

    winrt::com_ptr<IOleWindow> oleWindow;
    hr = namespaceTree->QueryInterface(IID_PPV_ARGS(oleWindow.put()));
    if (FAILED(hr) || !oleWindow) {
        return false;
    }

    HWND namespaceTreeWindow = nullptr;
    if (FAILED(oleWindow->GetWindow(&namespaceTreeWindow)) ||
        !namespaceTreeWindow) {
        return false;
    }

    *treeViewOut = FindWindowExW(namespaceTreeWindow, nullptr,
                                 L"SysTreeView32", nullptr);
    return *treeViewOut != nullptr;
}

struct NavigationPaneVisibilityContext {
    bool foundVisibleTreeView = false;
};

BOOL CALLBACK FindVisibleNavigationTreeViewProc(HWND hWnd, LPARAM lParam) {
    auto* context = reinterpret_cast<NavigationPaneVisibilityContext*>(lParam);
    if (IsWindowClass(hWnd, L"SysTreeView32") && IsWindowVisible(hWnd)) {
        context->foundVisibleTreeView = true;
        return FALSE;
    }

    return TRUE;
}

bool IsNavigationPaneVisibleByTreeView(HWND hWnd, bool* visible) {
    if (!visible) {
        return false;
    }

    winrt::com_ptr<IShellBrowser> shellBrowser;
    if (GetShellBrowserFromChildWindow(hWnd, shellBrowser)) {
        HWND treeView = nullptr;
        if (GetNavigationTreeViewFromShellBrowser(shellBrowser.get(),
                                                  &treeView)) {
            *visible = IsWindowVisible(treeView);
            return true;
        }
    }

    HWND shellTab = FindShellTabWindowFromChild(hWnd);
    if (!shellTab) {
        return false;
    }

    NavigationPaneVisibilityContext context;
    EnumChildWindows(shellTab, FindVisibleNavigationTreeViewProc,
                     reinterpret_cast<LPARAM>(&context));

    *visible = context.foundVisibleTreeView;
    return true;
}

HWND FindDefViewFromChild(HWND hWnd) {
    for (HWND current = hWnd; current; current = GetParent(current)) {
        if (IsWindowClass(current, L"SHELLDLL_DefView")) {
            return current;
        }
    }

    return nullptr;
}

bool GetStoredFileListInset(HWND defView, int* inset) {
    HANDLE value = GetPropW(defView, kFileListInsetProperty);
    if (!value) {
        return false;
    }

    *inset = static_cast<int>(reinterpret_cast<INT_PTR>(value) - 1);
    return true;
}

void SetSingleFileListLeftInset(HWND defView, HWND fileList, int inset) {
    if (!fileList) {
        return;
    }

    RECT fileListRect;
    RECT defViewRect;
    if (!GetWindowRect(fileList, &fileListRect) ||
        !GetClientRect(defView, &defViewRect)) {
        return;
    }
    MapWindowPoints(nullptr, defView,
                    reinterpret_cast<POINT*>(&fileListRect), 2);

    // Keep Explorer's current top and bottom, and anchor the view to the
    // DefView's right edge. Only the left edge is inset, which works for both
    // DirectUIHWND and classic SysListView32 folder views without affecting
    // the navigation pane itself.
    int right = std::max(defViewRect.right, 0L);
    int left = std::clamp(inset, 0, right);
    int width = right - left;
    int height = std::max(fileListRect.bottom - fileListRect.top, 0L);

    if (fileListRect.left == left &&
        fileListRect.right - fileListRect.left == width) {
        return;
    }

    SetWindowPos(fileList, nullptr, left, fileListRect.top, width, height,
                 SWP_NOZORDER | SWP_NOACTIVATE);
}

void SetFileListLeftInset(HWND defView, int inset) {
    inset = std::max(inset, 0);
    if (!SetPropW(defView, kFileListInsetProperty,
                  reinterpret_cast<HANDLE>(
                      static_cast<INT_PTR>(inset + 1)))) {
        Wh_Log(L"Failed to store file-list inset for %p", defView);
    }

    // Explorer can temporarily retain both view implementations while
    // changing folders or view modes, so update every matching direct child.
    constexpr PCWSTR fileListClasses[] = {L"DirectUIHWND",
                                           L"SysListView32"};
    for (PCWSTR className : fileListClasses) {
        HWND fileList = nullptr;
        while ((fileList =
                    FindWindowExW(defView, fileList, className, nullptr))) {
            SetSingleFileListLeftInset(defView, fileList, inset);
        }
    }
}

void ReapplyStoredFileListInset(HWND defView) {
    int inset = 0;
    if (GetStoredFileListInset(defView, &inset)) {
        SetFileListLeftInset(defView, inset);
    }
}

void AdjustFileListWindowPos(HWND fileList, WINDOWPOS* windowPos) {
    if (!windowPos ||
        ((windowPos->flags & SWP_NOMOVE) &&
         (windowPos->flags & SWP_NOSIZE))) {
        return;
    }

    HWND defView = GetParent(fileList);
    int inset = 0;
    if (!defView || !GetStoredFileListInset(defView, &inset)) {
        return;
    }

    RECT defViewRect;
    RECT fileListRect;
    if (!GetClientRect(defView, &defViewRect) ||
        !GetWindowRect(fileList, &fileListRect)) {
        return;
    }
    MapWindowPoints(nullptr, defView,
                    reinterpret_cast<POINT*>(&fileListRect), 2);

    int right = std::max(defViewRect.right, 0L);
    int left = std::clamp(inset, 0, right);

    if (windowPos->flags & SWP_NOMOVE) {
        windowPos->y = fileListRect.top;
    }
    if (windowPos->flags & SWP_NOSIZE) {
        windowPos->cy =
            std::max(fileListRect.bottom - fileListRect.top, 0L);
    }

    windowPos->x = left;
    windowPos->cx = right - left;
    windowPos->flags &= ~(SWP_NOMOVE | SWP_NOSIZE);
}

void UpdateFileListInset(
    HWND defView,
    NavigationPaneVisibilityHint visibilityHint =
        NavigationPaneVisibilityHint::Query) {
    bool navigationPaneVisible = false;

    if (g_unloading) {
        navigationPaneVisible = true;
    } else if (visibilityHint == NavigationPaneVisibilityHint::Visible) {
        navigationPaneVisible = true;
    } else if (visibilityHint == NavigationPaneVisibilityHint::Hidden) {
        navigationPaneVisible = false;
    } else if (!ReadPerBrowserBoolProperty(
                   defView, L"PageSpaceControlSizer_Visible",
                   &navigationPaneVisible) &&
               !IsNavigationPaneVisibleByTreeView(
                   defView, &navigationPaneVisible)) {
        Wh_Log(L"Failed to determine navigation pane visibility for %p",
               defView);
        return;
    }

    int inset = 0;
    if (!navigationPaneVisible) {
        UINT dpi = GetDpiForWindow(defView);
        if (!dpi) {
            dpi = USER_DEFAULT_SCREEN_DPI;
        }
        inset = MulDiv(kHiddenNavigationPaneFileListInsetDip, dpi,
                       USER_DEFAULT_SCREEN_DPI);
    }

    SetFileListLeftInset(defView, inset);
}

void PostFileListInsetUpdate(
    HWND hWnd,
    NavigationPaneVisibilityHint visibilityHint =
        NavigationPaneVisibilityHint::Query) {
    HWND defView = FindDefViewFromChild(hWnd);
    if (defView && g_updateFileListInsetMessage) {
        PostMessageW(defView, g_updateFileListInsetMessage,
                     static_cast<WPARAM>(visibilityHint), 0);
    }
}

void SendAltShiftP(HWND hWnd) {
    HWND topLevel = GetAncestor(hWnd, GA_ROOT);
    if (topLevel) {
        SetForegroundWindow(topLevel);
    }

    INPUT inputs[6] = {};

    inputs[0].type = INPUT_KEYBOARD;
    inputs[0].ki.wVk = VK_MENU;

    inputs[1].type = INPUT_KEYBOARD;
    inputs[1].ki.wVk = VK_SHIFT;

    inputs[2].type = INPUT_KEYBOARD;
    inputs[2].ki.wVk = 'P';

    inputs[3].type = INPUT_KEYBOARD;
    inputs[3].ki.wVk = 'P';
    inputs[3].ki.dwFlags = KEYEVENTF_KEYUP;

    inputs[4].type = INPUT_KEYBOARD;
    inputs[4].ki.wVk = VK_SHIFT;
    inputs[4].ki.dwFlags = KEYEVENTF_KEYUP;

    inputs[5].type = INPUT_KEYBOARD;
    inputs[5].ki.wVk = VK_MENU;
    inputs[5].ki.dwFlags = KEYEVENTF_KEYUP;

    UINT sent = SendInput(ARRAYSIZE(inputs), inputs, sizeof(INPUT));
    if (sent != ARRAYSIZE(inputs)) {
        Wh_Log(L"Failed to send Alt+Shift+P, sent %u of %u inputs",
               sent, ARRAYSIZE(inputs));
    }
}

void SendToggleNavigationPane(HWND hWnd) {
    bool visible = false;
    if (!ReadPerBrowserBoolProperty(
            hWnd, L"PageSpaceControlSizer_Visible", &visible) &&
        !IsNavigationPaneVisibleByTreeView(hWnd, &visible)) {
        Wh_Log(L"Failed to determine navigation pane visibility");
        return;
    }

    bool newVisible = !visible;
    if (!WritePerBrowserBoolProperty(
            hWnd, L"PageSpaceControlSizer_Visible", newVisible)) {
        Wh_Log(L"Failed to toggle navigation pane");
        return;
    }

    // Explorer applies the pane layout asynchronously. Queue the file-list
    // update with the state we just wrote instead of querying stale UI state.
    PostFileListInsetUpdate(
        hWnd, newVisible ? NavigationPaneVisibilityHint::Visible
                         : NavigationPaneVisibilityHint::Hidden);
}

void OnEmptySpaceTrigger(HWND hWnd, TriggerButton button) {
    if (g_settings.detailsPaneButton == button) {
        SendAltShiftP(hWnd);
    }
    if (g_settings.navigationPaneButton == button) {
        SendToggleNavigationPane(hWnd);
    }
}

bool IsSysListViewEmptySpace(HWND hWnd, LPARAM lParam) {
    LVHITTESTINFO hitTestInfo = {};
    hitTestInfo.pt.x = GET_X_LPARAM(lParam);
    hitTestInfo.pt.y = GET_Y_LPARAM(lParam);

    return ListView_SubItemHitTest(hWnd, &hitTestInfo) == -1;
}

LRESULT CALLBACK SysListViewSubclass(HWND hWnd,
                                     UINT uMsg,
                                     WPARAM wParam,
                                     LPARAM lParam,
                                     DWORD_PTR dwRefData) {
    if (uMsg == WM_WINDOWPOSCHANGING) {
        AdjustFileListWindowPos(hWnd,
                                reinterpret_cast<WINDOWPOS*>(lParam));
    }

    switch (uMsg) {
        // The left button triggers on double-click; a single left-click is
        // Explorer's normal select/deselect. The middle button has no native
        // action on empty space, so it triggers on a single click.
        case WM_LBUTTONDBLCLK:
            if (ButtonHasAction(TriggerButton::Left) &&
                IsSysListViewEmptySpace(hWnd, lParam)) {
                OnEmptySpaceTrigger(hWnd, TriggerButton::Left);
            }
            break;

        case WM_MBUTTONDOWN:
            if (ButtonHasAction(TriggerButton::Middle) &&
                IsSysListViewEmptySpace(hWnd, lParam)) {
                OnEmptySpaceTrigger(hWnd, TriggerButton::Middle);
            }
            break;
    }

    LRESULT result = DefSubclassProc(hWnd, uMsg, wParam, lParam);
    if (uMsg == WM_NCDESTROY) {
        ForgetSubclassedWindow(g_SubclassedSysListViews, hWnd);
    }

    return result;
}

LRESULT CALLBACK DirectUIWindowSubclass(HWND hWnd,
                                        UINT uMsg,
                                        WPARAM wParam,
                                        LPARAM lParam,
                                        DWORD_PTR dwRefData) {
    if (uMsg == WM_WINDOWPOSCHANGING) {
        AdjustFileListWindowPos(hWnd,
                                reinterpret_cast<WINDOWPOS*>(lParam));
    }

    LRESULT result = DefSubclassProc(hWnd, uMsg, wParam, lParam);
    if (uMsg == WM_NCDESTROY) {
        ForgetSubclassedWindow(g_SubclassedDirectUIViews, hWnd);
    }

    return result;
}

bool IsDirectUIEmptySpaceAtCursor() {
    if (!g_pUIAutomation) {
        return false;
    }

    POINT screenPoint = {};
    GetCursorPos(&screenPoint);

    winrt::com_ptr<IUIAutomationElement> element;
    if (FAILED(g_pUIAutomation->ElementFromPoint(screenPoint, element.put())) ||
        !element) {
        return false;
    }

    bstr_ptr bstrClassName;
    if (FAILED(element->get_CurrentClassName(bstrClassName.GetAddress()))) {
        return false;
    }

    wchar_t className[256] = {};
    CopyClassName(className, bstrClassName.GetBSTR());
    return IsDirectUIEmptySpaceClass(className);
}

LRESULT CALLBACK DefViewSubclass(HWND hWnd,
                                 UINT uMsg,
                                 WPARAM wParam,
                                 LPARAM lParam,
                                 DWORD_PTR dwRefData) {
    if (uMsg == g_updateFileListInsetMessage) {
        UpdateFileListInset(
            hWnd, static_cast<NavigationPaneVisibilityHint>(wParam));
        return 0;
    }

    if (uMsg == WM_PARENTNOTIFY && LOWORD(wParam) == WM_LBUTTONDOWN &&
        ButtonHasAction(TriggerButton::Left) &&
        IsDirectUIEmptySpaceAtCursor()) {
        DWORD time = (DWORD)GetMessageTime();
        POINT pt = {GET_X_LPARAM(lParam), GET_Y_LPARAM(lParam)};

        if (IsSecondClickOfDoubleClick(g_lastDefViewEmptyClick, hWnd, time,
                                       pt)) {
            g_lastDefViewEmptyClick = {};
            OnEmptySpaceTrigger(hWnd, TriggerButton::Left);
        } else {
            g_lastDefViewEmptyClick = {hWnd, time, pt};
        }
    } else if (uMsg == WM_PARENTNOTIFY && LOWORD(wParam) == WM_MBUTTONDOWN &&
               ButtonHasAction(TriggerButton::Middle) &&
               IsDirectUIEmptySpaceAtCursor()) {
        OnEmptySpaceTrigger(hWnd, TriggerButton::Middle);
    }

    LRESULT result = DefSubclassProc(hWnd, uMsg, wParam, lParam);

    // Explorer can reset its child geometry while resizing for the details
    // pane. Restore the already-known inset synchronously, before this layout
    // message returns and Windows gets a chance to paint an unpadded frame.
    // The queued visibility check is still needed for pane changes made
    // outside this mod.
    if (!g_unloading &&
        (uMsg == WM_SIZE || uMsg == WM_WINDOWPOSCHANGED ||
         (uMsg == WM_SHOWWINDOW && wParam))) {
        ReapplyStoredFileListInset(hWnd);
        PostFileListInsetUpdate(hWnd);
    }

    if (uMsg == WM_NCDESTROY) {
        RemovePropW(hWnd, kFileListInsetProperty);
        ForgetSubclassedWindow(g_SubclassedDefViews, hWnd);
    }

    return result;
}

void SubclassSysListView(HWND hWnd) {
    if (std::find(g_SubclassedSysListViews.begin(),
                  g_SubclassedSysListViews.end(),
                  hWnd) != g_SubclassedSysListViews.end()) {
        return;
    }

    if (WindhawkUtils::SetWindowSubclassFromAnyThread(
            hWnd, SysListViewSubclass, 0)) {
        RememberSubclassedWindow(g_SubclassedSysListViews, hWnd);
        Wh_Log(L"SysListView32 subclassed %p", hWnd);
    }
}

void SubclassDirectUIView(HWND hWnd) {
    if (std::find(g_SubclassedDirectUIViews.begin(),
                  g_SubclassedDirectUIViews.end(),
                  hWnd) != g_SubclassedDirectUIViews.end()) {
        return;
    }

    if (WindhawkUtils::SetWindowSubclassFromAnyThread(
            hWnd, DirectUIWindowSubclass, 0)) {
        RememberSubclassedWindow(g_SubclassedDirectUIViews, hWnd);
        Wh_Log(L"DirectUIHWND subclassed %p", hWnd);
    }
}

void SubclassDefView(HWND hWnd) {
    if (std::find(g_SubclassedDefViews.begin(), g_SubclassedDefViews.end(),
                  hWnd) != g_SubclassedDefViews.end()) {
        return;
    }

    if (WindhawkUtils::SetWindowSubclassFromAnyThread(hWnd, DefViewSubclass,
                                                      0)) {
        RememberSubclassedWindow(g_SubclassedDefViews, hWnd);
        Wh_Log(L"SHELLDLL_DefView subclassed %p", hWnd);
        PostFileListInsetUpdate(hWnd);
    }
}

void TrySubclassExplorerView(HWND hWnd) {
    HWND parent = GetParent(hWnd);
    if (!parent || !IsWindowClass(parent, L"SHELLDLL_DefView") ||
        !HasShellTabWindowParent(parent)) {
        return;
    }

    if (IsWindowClass(hWnd, L"SysListView32")) {
        SubclassSysListView(hWnd);
        SubclassDefView(parent);
    } else if (IsWindowClass(hWnd, L"DirectUIHWND")) {
        SubclassDirectUIView(hWnd);
        SubclassDefView(parent);
    }

    PostFileListInsetUpdate(parent);
}

using CreateWindowExW_t = decltype(&CreateWindowExW);
CreateWindowExW_t CreateWindowExW_Original;

HWND WINAPI CreateWindowExW_Hook(DWORD dwExStyle,
                                 LPCWSTR lpClassName,
                                 LPCWSTR lpWindowName,
                                 DWORD dwStyle,
                                 int X,
                                 int Y,
                                 int nWidth,
                                 int nHeight,
                                 HWND hWndParent,
                                 HMENU hMenu,
                                 HINSTANCE hInstance,
                                 LPVOID lpParam) {
    HWND hWnd = CreateWindowExW_Original(
        dwExStyle, lpClassName, lpWindowName, dwStyle, X, Y, nWidth, nHeight,
        hWndParent, hMenu, hInstance, lpParam);

    if (hWnd) {
        TrySubclassExplorerView(hWnd);
    }

    return hWnd;
}

BOOL CALLBACK InitEnumChildWindowsProc(HWND hWnd, LPARAM lParam) {
    DWORD pid = 0;
    GetWindowThreadProcessId(hWnd, &pid);
    if (pid != GetCurrentProcessId()) {
        return TRUE;
    }

    if (IsWindowClass(hWnd, L"SHELLDLL_DefView") &&
        HasShellTabWindowParent(hWnd)) {
        HWND listView = FindWindowExW(hWnd, nullptr, L"SysListView32",
                                      nullptr);
        HWND directUI = FindWindowExW(hWnd, nullptr, L"DirectUIHWND",
                                      nullptr);

        if (listView) {
            SubclassSysListView(listView);
            SubclassDefView(hWnd);
        }
        if (directUI) {
            SubclassDirectUIView(directUI);
            SubclassDefView(hWnd);
        }
    }

    return TRUE;
}

BOOL CALLBACK InitEnumWindowsProc(HWND hWnd, LPARAM lParam) {
    DWORD pid = 0;
    GetWindowThreadProcessId(hWnd, &pid);
    if (pid == GetCurrentProcessId() && IsWindowClass(hWnd, L"CabinetWClass")) {
        EnumChildWindows(hWnd, InitEnumChildWindowsProc, 0);
    }

    return TRUE;
}

BOOL Wh_ModInit() {
    Wh_Log(L"Explorer Toggle Details Pane Init");

    LoadSettings();

    g_updateFileListInsetMessage = RegisterWindowMessageW(
        L"Windhawk.explorer-toggle-details-pane.UpdateFileListInset");
    if (!g_updateFileListInsetMessage) {
        Wh_Log(L"Failed to register file-list inset update message");
        return FALSE;
    }

    WindhawkUtils::SetFunctionHook((void*)CreateWindowExW,
                                   (void*)CreateWindowExW_Hook,
                                   (void**)&CreateWindowExW_Original);

    if (!g_comInitializer.Init()) {
        Wh_Log(L"COM initialization failed");
        return FALSE;
    }

    HRESULT hr = CoCreateInstance(CLSID_CUIAutomation, nullptr,
                                  CLSCTX_INPROC_SERVER,
                                  __uuidof(IUIAutomation),
                                  g_pUIAutomation.put_void());
    if (FAILED(hr) || !g_pUIAutomation) {
        Wh_Log(L"Failed to create UIAutomation COM instance: 0x%08X", hr);
        return FALSE;
    }

    return TRUE;
}

void Wh_ModAfterInit() {
    EnumWindows(InitEnumWindowsProc, 0);
}

void Wh_ModSettingsChanged() {
    LoadSettings();
}

void Wh_ModUninit() {
    g_unloading = true;

    // Restore each list on the owning Explorer UI thread before removing the
    // subclasses which enforce its geometry.
    for (HWND hWnd : g_SubclassedDefViews) {
        if (!IsWindow(hWnd) ||
            !IsWindowClass(hWnd, L"SHELLDLL_DefView")) {
            continue;
        }

        DWORD_PTR messageResult = 0;
        if (!SendMessageTimeoutW(
                hWnd, g_updateFileListInsetMessage,
                static_cast<WPARAM>(NavigationPaneVisibilityHint::Visible),
                0, SMTO_ABORTIFHUNG | SMTO_BLOCK, 2000,
                &messageResult)) {
            Wh_Log(L"UI-thread file-list restoration failed for %p", hWnd);
            SetFileListLeftInset(hWnd, 0);
        }
    }

    for (HWND hWnd : g_SubclassedSysListViews) {
        if (IsWindow(hWnd) && IsWindowClass(hWnd, L"SysListView32")) {
            WindhawkUtils::RemoveWindowSubclassFromAnyThread(
                hWnd, SysListViewSubclass);
            Wh_Log(L"SysListView32 unsubclassed %p", hWnd);
        }
    }

    for (HWND hWnd : g_SubclassedDirectUIViews) {
        if (IsWindow(hWnd) && IsWindowClass(hWnd, L"DirectUIHWND")) {
            WindhawkUtils::RemoveWindowSubclassFromAnyThread(
                hWnd, DirectUIWindowSubclass);
            Wh_Log(L"DirectUIHWND unsubclassed %p", hWnd);
        }
    }

    for (HWND hWnd : g_SubclassedDefViews) {
        if (IsWindow(hWnd) &&
            IsWindowClass(hWnd, L"SHELLDLL_DefView")) {
            WindhawkUtils::RemoveWindowSubclassFromAnyThread(hWnd,
                                                             DefViewSubclass);
            RemovePropW(hWnd, kFileListInsetProperty);
            Wh_Log(L"SHELLDLL_DefView unsubclassed %p", hWnd);
        }
    }

    g_SubclassedSysListViews.clear();
    g_SubclassedDirectUIViews.clear();
    g_SubclassedDefViews.clear();
    g_pUIAutomation = nullptr;
    g_comInitializer.Uninit();

    Wh_Log(L"Explorer Toggle Details Pane Uninit");
}
